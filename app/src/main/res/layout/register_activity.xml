<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_app">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:id="@+id/main"
        android:padding="28dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Crear cuenta"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/coca_red"
            android:layout_marginTop="50dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Empieza tu cambio saludable"
            android:textSize="16sp"
            android:textColor="@color/text_muted"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="35dp" />

        <EditText
            android:id="@+id/etNombre"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Nombre completo"
            android:padding="14dp"
            android:background="@color/white"
            android:textColor="@color/text_main"
            android:textColorHint="@color/text_muted" />

        <EditText
            android:id="@+id/etCorreo"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Correo electrónico"
            android:inputType="textEmailAddress"
            android:padding="14dp"
            android:background="@color/white"
            android:textColor="@color/text_main"
            android:textColorHint="@color/text_muted"
            android:layout_marginTop="14dp" />

        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Contraseña"
            android:inputType="textPassword"
            android:padding="14dp"
            android:background="@color/white"
            android:textColor="@color/text_main"
            android:textColorHint="@color/text_muted"
            android:layout_marginTop="14dp" />

        <EditText
            android:id="@+id/etConfirmPassword"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Confirmar contraseña"
            android:inputType="textPassword"
            android:padding="14dp"
            android:background="@color/white"
            android:textColor="@color/text_main"
            android:textColorHint="@color/text_muted"
            android:layout_marginTop="14dp" />

        <Button
            android:id="@+id/btnCrearCuenta"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:text="Crear cuenta"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:backgroundTint="@color/coca_red"
            android:layout_marginTop="28dp" />

        <TextView
            android:id="@+id/tvIrLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ya tengo cuenta"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/water_blue_btn"
            android:layout_marginTop="22dp" />

    </LinearLayout>
</ScrollView>