<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_app"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:background="@drawable/degrado"
            android:padding="24dp">

            <TextView
                android:id="@+id/txtSaludo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:layout_marginBottom="16dp"
                android:text="Vamos por tu mejor versión"
                android:textColor="@color/text_main"
                android:textSize="22sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/imgCampana"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_alignParentEnd="true"
                android:layout_alignParentBottom="true"
                android:layout_marginBottom="12dp"
                android:src="@drawable/ic_notification"
                android:clickable="true"
                android:focusable="true"
                android:padding="4dp"
                app:tint="@color/text_main" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="-20dp"
            android:background="@drawable/bg_top_corners_white"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.CocaBreak.Card.Coca"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    app:strokeWidth="0dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/lblCoca"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Coca-Cola hoy"
                            android:textColor="@color/coca_red"
                            android:textStyle="bold"
                            android:textSize="15sp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/lblCoca"
                            android:layout_marginTop="14dp">

                            <TextView
                                android:id="@+id/txtCocaHoy"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/text_main"
                                android:textSize="28sp"
                                android:textStyle="bold" />

                        </LinearLayout>
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="50dp"
                            android:layout_alignParentEnd="true"
                            android:layout_below="@id/lblCoca"
                            android:src="@drawable/ic_soda" />
                    </RelativeLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.CocaBreak.Card.Water"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    app:strokeWidth="0dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/lblAgua"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Agua hoy"
                            android:textColor="@color/water_blue_btn"
                            android:textStyle="bold"
                            android:textSize="15sp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/lblAgua"
                            android:layout_marginTop="14dp"
                            android:orientation="horizontal"
                            android:baselineAligned="false">

                            <TextView
                                android:id="@+id/txtAguaHoy"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0L"
                                android:textColor="@color/text_main"
                                android:textSize="28sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=""
                                android:textColor="@color/text_muted"
                                android:textSize="14sp"
                                android:layout_gravity="bottom"
                                android:layout_marginBottom="4dp"/>
                        </LinearLayout>

                        <ImageView
                            android:layout_width="30dp"
                            android:layout_height="40dp"
                            android:layout_alignParentEnd="true"
                            android:layout_below="@id/lblAgua"
                            android:layout_marginTop="8dp"
                            android:src="@drawable/ic_agua" />
                    </RelativeLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardReto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/white"
                app:strokeColor="@color/border_gray"
                app:strokeWidth="1dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/lblRetoTitulo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reto Activo"
                        android:textColor="@color/text_main"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtRetoActivo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/lblRetoTitulo"
                        android:layout_marginTop="4dp"
                        android:text="Reduce 20% esta semana"
                        android:textColor="@color/text_main"
                        android:textStyle="bold"
                        android:textSize="14sp" />

                    <ProgressBar
                        android:id="@+id/progressReto"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="200dp"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/txtRetoActivo"
                        android:layout_marginTop="12dp"
                        android:progress="42"
                        android:progressTint="@color/coca_red" />

                    <TextView
                        android:id="@+id/txtRetoProgreso"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/progressReto"
                        android:layout_alignTop="@id/progressReto"
                        android:layout_alignBottom="@id/progressReto"
                        android:layout_marginStart="8dp"
                        android:gravity="center_vertical"
                        android:text="3/7 días"
                        android:textColor="@color/text_main"
                        android:textSize="12sp"
                        android:textStyle="bold"/>

                    <ImageView
                        android:layout_width="45dp"
                        android:layout_height="45dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_retos" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Resumen de hoy"
                android:textColor="@color/text_main"
                android:textSize="20sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/white"
                app:strokeColor="@color/border_gray"
                app:strokeWidth="1dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <TableLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:stretchColumns="1">

                    <TableRow android:layout_marginBottom="16dp" android:gravity="center_vertical">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_sugar" app:tint="@color/text_muted"/>
                        <TextView android:text="Azúcar consumida" android:paddingStart="12dp" android:textColor="@color/text_main" android:textStyle="bold" android:textSize="15sp"/>
                        <TextView
                            android:id="@+id/txtAzucar"
                            android:text="0g"
                            android:gravity="end" android:textColor="@color/text_main" android:textStyle="bold" android:textSize="15sp"/>
                    </TableRow>

                    <TableRow android:layout_marginBottom="16dp" android:gravity="center_vertical">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_calories" app:tint="@color/text_muted"/>
                        <TextView android:text="Calorías" android:paddingStart="12dp" android:textColor="@color/text_main" android:textStyle="bold" android:textSize="15sp"/>
                        <TextView
                            android:id="@+id/txtCalorias"
                            android:text="0 kcal"  android:gravity="end" android:textColor="@color/text_main" android:textStyle="bold" android:textSize="15sp"/>
                    </TableRow>

                    <TableRow android:gravity="center_vertical">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_money" app:tint="@color/text_muted"/>
                        <TextView android:text="Dinero gastado" android:paddingStart="12dp" android:textColor="@color/text_main" android:textStyle="bold" android:textSize="15sp"/>
                        <TextView
                            android:id="@+id/txtDinero"
                            android:text="$0.00"
                            android:gravity="end" android:textColor="@color/text_main" android:textStyle="bold" android:textSize="15sp"/>
                    </TableRow>
                </TableLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLogro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/white"
                app:strokeColor="@color/border_gray"
                app:strokeWidth="1dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_toStartOf="@id/imgBadge"
                        android:layout_alignParentStart="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Logro reciente"
                            android:textColor="@color/text_muted"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/txtLogroReciente"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Primer paso"
                            android:textColor="@color/text_main"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/txtDescripcionLogro"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="¡Bien hecho, sigue así! Tú puedes"
                            android:textColor="@color/text_main"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/imgBadge"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_logros" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Comunidad"
                android:textColor="@color/text_main"
                android:textSize="20sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardGrupo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#E8F5E9"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/imgGrupo"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_grupos" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/imgGrupo"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mis grupos"
                            android:textColor="@color/text_main"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:id="@+id/txtMisGrupos"
                            android:text="0 grupos activos"
                            android:textColor="@color/text_muted"
                            android:textSize="13sp" />


                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="Ver"
                        android:textColor="@color/water_blue_btn"
                        android:textStyle="bold" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardChat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#E3F2FD"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/imgChat"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_chat" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/imgChat"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Chat grupal"
                            android:textColor="@color/text_main"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:id="@+id/txtMensajes"
                            android:text="0 mensajes nuevos"
                            android:textColor="@color/text_muted"
                            android:textSize="13sp" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="Abrir"
                        android:textColor="@color/coca_red"
                        android:textStyle="bold" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </LinearLayout>
</ScrollView>