<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="40dp"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="-0.02"
            android:text="Bienvenido!"
            android:textColor="@color/coca_red"
            android:textSize="36sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="sans-serif-medium"
            android:lineSpacingMultiplier="1.2"
            android:text="Inicia sesión para continuar\ntu cambio"
            android:textAlignment="center"
            android:textColor="@color/text_main"
            android:textSize="15sp" />
    </LinearLayout>

    <EditText
        android:id="@+id/edCorreo"
        style="@style/Widget.CocaBreak.EditText"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/bg_input_rounded"
        android:drawableStart="@android:drawable/ic_menu_my_calendar"
        android:drawablePadding="12dp"
        android:hint="Correo electrónico"
        android:inputType="textEmailAddress"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        tools:ignore="UseCompatTextViewDrawableXml" />

    <EditText
        android:id="@+id/edPassword"
        style="@style/Widget.CocaBreak.EditText"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_input_rounded"
        android:drawableStart="@android:drawable/ic_secure"
        android:drawablePadding="12dp"
        android:hint="Contraseña"
        android:inputType="textPassword|textNoSuggestions"
        android:paddingStart="20dp"
        android:paddingEnd="20dp" />

    <TextView
        android:id="@+id/tvForgotPassword"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginTop="12dp"
        android:clickable="true"
        android:focusable="true"
        android:fontFamily="sans-serif-medium"
        android:minHeight="48dp"
        android:text="¿Olvidaste tu contraseña?"
        android:textColor="@color/coca_red"
        android:textSize="12sp" />

    <Button
        android:id="@+id/btnLogin"
        style="@style/Widget.CocaBreak.Button.Red"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="32dp"
        android:text="Iniciar sesión" />

    <TextView
        android:id="@+id/tvRegistrarse"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:clickable="true"
        android:focusable="true"
        android:fontFamily="sans-serif"
        android:minHeight="48dp"
        android:text="¿No tienes cuenta? Regístrate"
        android:textColor="@color/coca_red"
        android:textSize="14sp" />

</LinearLayout>